{
  "name": "llm-queue",
  "version": "0.2.0",
  "description": "Single-worker priority queue for a local LLM (Ollama), with browser/Node/service transports and an OpenAI-compatible shared HTTP service.",
  "type": "module",
  "license": "UNLICENSED",
  "bin": {
    "llm-queue": "./dist/cli.js"
  },
  "exports": {
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "serve": "node dist/cli.js serve",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4"
  }
}
